// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  user
  admin
}

enum UserStatus {
  active
  banned
}

enum ProductStatus {
  active
  draft
  sold_out
  archived
}

enum ProductBadge {
  New
  Sale
  Hot
}

enum OrderStatus {
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  card
  upi
  bank_transfer
}

enum SaleStatus {
  completed
  pending
  refunded
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  name      String
  email     String     @unique
  role      Role       @default(user)
  avatar    String?
  phone     String?
  status    UserStatus @default(active)
  joinedAt  DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  orders                  Order[]
  cartItems               CartItem[]
  reviews                 Review[]
  addresses               Address[]
  sellerProducts          SellerProduct[]
  sellerSales             SellerSale[]
  products                Product[]                @relation("SellerProducts")
  wishlists               Wishlist[]
  notificationPreferences NotificationPreferences?

  @@map("users")
}

// ─────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String
  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCT (marketplace / admin-managed)
// ─────────────────────────────────────────────

model Product {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  description   String
  price         Float
  originalPrice Float?
  images        String[]
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id])
  tags          String[]
  rating        Float        @default(0)
  reviewCount   Int          @default(0)
  stock         Int          @default(0)
  badge         ProductBadge?
  specs         Json?
  sellerId      String?
  seller        User?        @relation("SellerProducts", fields: [sellerId], references: [id])
  sellerName    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  reviews    Review[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  wishlists  Wishlist[]

  @@map("products")
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  rating      Int
  comment     String
  userName    String
  userAvatar  String?
  createdAt   DateTime @default(now())

  @@map("reviews")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model CartItem {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int
  selectedVariant Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  total           Float
  status          OrderStatus @default(processing)
  shippingAddress Json        // Stored as JSON (Address type from frontend)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  title     String   // Snapshot at time of order
  image     String   // Snapshot at time of order
  price     Float    // Snapshot at time of order
  quantity  Int

  @@map("order_items")
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  fullName  String
  line1     String
  line2     String?
  city      String
  state     String
  zip       String
  country   String
  phone     String?
  email     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("addresses")
}

// ─────────────────────────────────────────────
// SELLER PRODUCT (per-seller, separate from marketplace)
// ─────────────────────────────────────────────

model SellerProduct {
  id            String        @id @default(cuid())
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  sellerName    String
  title         String
  slug          String
  description   String
  price         Float
  originalPrice Float?
  images        String[]
  category      String
  stock         Int
  status        ProductStatus @default(draft)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sales SellerSale[]

  @@unique([sellerId, slug])
  @@map("seller_products")
}

// ─────────────────────────────────────────────
// SELLER SALE (POS / direct sale record)
// ─────────────────────────────────────────────

model SellerSale {
  id             String        @id @default(cuid())
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])
  productId      String
  product        SellerProduct @relation(fields: [productId], references: [id])
  productTitle   String
  productImage   String
  buyerName      String
  buyerEmail     String
  quantity       Int
  unitPrice      Float
  totalAmount    Float
  paymentMethod  PaymentMethod
  status         SaleStatus    @default(completed)
  date           DateTime      @default(now())

  @@map("seller_sales")
}

// ─────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlists")
}

// ─────────────────────────────────────────────
// NOTIFICATION PREFERENCES
// ─────────────────────────────────────────────

model NotificationPreferences {
  id                 String  @id @default(cuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications Boolean @default(true)
  orderUpdates       Boolean @default(true)
  promotions         Boolean @default(false)

  @@map("notification_preferences")
}

// ─────────────────────────────────────────────
// ORDER STATUS HISTORY
// ─────────────────────────────────────────────

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  changedBy String?
  note      String?
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// TESTIMONIAL (landing page)
// ─────────────────────────────────────────────

model Testimonial {
  id       String  @id @default(cuid())
  name     String
  role     String
  avatar   String?
  quote    String
  rating   Int
  isActive Boolean @default(true)

  @@map("testimonials")
}

// ─────────────────────────────────────────────
// FAQ (landing page)
// ─────────────────────────────────────────────

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  @@map("faqs")
}
